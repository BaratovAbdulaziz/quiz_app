{
  "name": "quiz-app",
  "private": true,
  "scripts": {
    "predev": "bash scripts/docker-up.sh",
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "npm run dev --workspace=@quiz-app/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "docker:up": "bash scripts/docker-up.sh"
  },
  "packageManager": "npm@11.13.0",
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
