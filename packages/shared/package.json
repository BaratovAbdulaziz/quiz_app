{
  "name": "@quiz-app/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate": "tsx src/migrate.ts",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "drizzle-zod": "^0.6.0",
    "zod": "^3.24.0",
    "postgres": "^3.4.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0"
  }
}
